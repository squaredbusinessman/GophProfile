    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Go runtime collector Prometheus показывает heap, goroutines и среднюю GC pause",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
