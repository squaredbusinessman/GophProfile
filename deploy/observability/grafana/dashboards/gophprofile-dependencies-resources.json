  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Pool metrics из sql.DBStats: connections и waits без SQL текста или DSN",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (db_client_connection_state) (db_client_connection_count{job=~\"gophprofile-$service\",instance=~\"$instance\"} and on(job, instance) target_info{deployment_environment=~\"$environment\"}) or on() vector(0)",
          "legendFormat": "{{db_client_connection_state}}",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "sum(rate(db_client_connection_wait_count_total{job=~\"gophprofile-$service\",instance=~\"$instance\"}[$__rate_interval]) and on(job, instance) target_info{deployment_environment=~\"$environment\"}) or on() vector(0)",
          "legendFormat": "wait rate",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "PostgreSQL open/in-use/idle/wait",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Manual repository histogram показывает latency DB boundaries без driver instrumentation",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, db_operation_name, db_collection_name) (rate(db_client_operation_duration_seconds_bucket{job=~\"gophprofile-$service\",instance=~\"$instance\"}[$__rate_interval]) and on(job, instance) target_info{deployment_environment=~\"$environment\"}))",
          "legendFormat": "{{db_operation_name}} {{db_collection_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "DB query latency p95",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "DB errors считаются только по безопасному result label, error text не экспортируется",
