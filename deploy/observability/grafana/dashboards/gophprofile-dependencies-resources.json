      "id": 8,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(go_memstats_heap_alloc_bytes{job=~\"gophprofile-$service\",instance=~\"$instance\"} and on(job, instance) target_info{deployment_environment=~\"$environment\"}) or on() vector(0)",
          "legendFormat": "heap bytes",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "sum(go_goroutines{job=~\"gophprofile-$service\",instance=~\"$instance\"} and on(job, instance) target_info{deployment_environment=~\"$environment\"}) or on() vector(0)",
          "legendFormat": "goroutines",
          "range": true,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "sum(rate(go_gc_duration_seconds_sum{job=~\"gophprofile-$service\",instance=~\"$instance\"}[$__rate_interval]) and on(job, instance) target_info{deployment_environment=~\"$environment\"}) / clamp_min(sum(rate(go_gc_duration_seconds_count{job=~\"gophprofile-$service\",instance=~\"$instance\"}[$__rate_interval]) and on(job, instance) target_info{deployment_environment=~\"$environment\"}), 1e-9) or on() vector(0)",
          "legendFormat": "gc pause avg seconds",
          "range": true,
          "refId": "C"
        }
      ],
      "title": "Go heap, goroutines, GC pause",
      "type": "timeseries"
    },
