{
  "annotations": {
    "list": []
  },
  "description": "Operational обзор доступности, HTTP RED, correlated logs и перехода log to Jaeger trace",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Значение up по server и worker с фильтром окружения из target_info",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "max by (job, instance) (up{job=~\"gophprofile-$service\",instance=~\"$instance\"} and on(job, instance) target_info{deployment_environment=~\"$environment\"})",
          "legendFormat": "{{job}} {{instance}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "service/instance availability",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "RED traffic: rate по нормализованным HTTP route и method",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (http_request_method, http_route) (rate(http_server_request_count_total{job=~\"gophprofile-$service\",instance=~\"$instance\"}[$__rate_interval]) and on(job, instance) target_info{deployment_environment=~\"$environment\"}) or on() vector(0)",
          "legendFormat": "{{http_request_method}} {{http_route}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "request rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Клиентские и серверные ошибки разделены по классам status code",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 7
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(http_server_request_count_total{job=~\"gophprofile-$service\",instance=~\"$instance\",http_response_status_code=~\"4..\"}[$__rate_interval]) and on(job, instance) target_info{deployment_environment=~\"$environment\"}) or on() vector(0)",
          "legendFormat": "4xx",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "sum(rate(http_server_request_count_total{job=~\"gophprofile-$service\",instance=~\"$instance\",http_response_status_code=~\"5..\"}[$__rate_interval]) and on(job, instance) target_info{deployment_environment=~\"$environment\"}) or on() vector(0)",
          "legendFormat": "5xx",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "4xx and 5xx rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Доля 5xx среди всех HTTP requests, clamp_min защищает пустые интервалы от ложных ошибок",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 4,
        "x": 8,
        "y": 7
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(http_server_request_count_total{job=~\"gophprofile-$service\",instance=~\"$instance\",http_response_status_code=~\"5..\"}[$__rate_interval]) and on(job, instance) target_info{deployment_environment=~\"$environment\"}) / clamp_min(sum(rate(http_server_request_count_total{job=~\"gophprofile-$service\",instance=~\"$instance\"}[$__rate_interval]) and on(job, instance) target_info{deployment_environment=~\"$environment\"}), 1e-9) or on() vector(0)",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "5xx error ratio",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Latency percentiles считаются по histogram buckets HTTP server duration",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_request_duration_seconds_bucket{job=~\"gophprofile-$service\",instance=~\"$instance\"}[$__rate_interval]) and on(job, instance) target_info{deployment_environment=~\"$environment\"})) or on() vector(0)",
          "legendFormat": "p50",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket{job=~\"gophprofile-$service\",instance=~\"$instance\"}[$__rate_interval]) and on(job, instance) target_info{deployment_environment=~\"$environment\"})) or on() vector(0)",
          "legendFormat": "p95",
          "range": true,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_request_duration_seconds_bucket{job=~\"gophprofile-$service\",instance=~\"$instance\"}[$__rate_interval]) and on(job, instance) target_info{deployment_environment=~\"$environment\"})) or on() vector(0)",
          "legendFormat": "p99",
          "range": true,
          "refId": "C"
        }
      ],
      "title": "p50/p95/p99 request duration",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Текущие активные HTTP requests по server process",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 4,
        "x": 0,
        "y": 14
      },
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(http_server_active_requests{job=~\"gophprofile-$service\",instance=~\"$instance\"} and on(job, instance) target_info{deployment_environment=~\"$environment\"}) or on() vector(0)",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "in-flight requests",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Top route latency использует нормализованный http_route, поэтому UUID не попадают в labels",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 4,
        "y": 14
      },
      "id": 7,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "topk(10, histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_seconds_bucket{job=~\"gophprofile-$service\",instance=~\"$instance\"}[$__rate_interval]) and on(job, instance) target_info{deployment_environment=~\"$environment\"})))",
          "legendFormat": "{{http_route}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "top routes by latency",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Loki считает JSON logs только по низкокардинальным labels service, environment и level",
      "fieldConfig": {
        "defaults": {
          "unit": "logs"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "id": 8,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (level) (count_over_time({environment=~\"$environment\",service=~\"$service\",level=~\"warn|error\"}[$__interval]))",
          "queryType": "range",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "ERROR/WARN logs over time",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Derived field TraceID в Loki datasource превращает trace_id из JSON log в ссылку на Jaeger trace",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "id": 9,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{environment=~\"$environment\",service=~\"$service\",level=\"error\"} | json",
          "queryType": "range",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "latest error logs with trace_id",
      "type": "logs"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 41,
  "tags": [
    "gophprofile",
    "provisioned",
    "observability"
  ],
